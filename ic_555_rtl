//IC 555 DESIGN
module ic555_timer (
    input wire gnd,
    input wire trigger,
    input wire reset,
    input wire control,
    input wire threshold,
    output reg discharge,
    input wire vcc,
  output reg out
);

reg latch;

always @(*) begin
    if (reset == 0)
        latch = 0;

    else begin
        if (trigger == 0)
            latch = 1;

        else if (threshold == 1)
            latch = 0;
    end
end

always @(*) begin
    out = latch;
    discharge = ~latch;
end

endmodule
